<%- include('partials/header') %>

<div class="hero">
  <div class="hero-badge">VULNERABLE APP</div>
  <h1>VulnWebApp</h1>
  <p class="hero-sub">Intentionally Vulnerable Web Application for Security Learning</p>
  <div class="vuln-grid">
    <a href="/login" class="vuln-card sqli-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">SQL Injection</div>
      <div class="vuln-desc">Bypass login with ' OR 1=1 --</div>
    </a>
    <a href="/comments" class="vuln-card xss-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">XSS</div>
      <div class="vuln-desc">Inject &lt;script&gt; into comments</div>
    </a>
    <a href="/upload" class="vuln-card upload-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">File Upload</div>
      <div class="vuln-desc">Upload any file type</div>
    </a>
    <a href="/profile?id=1" class="vuln-card idor-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">IDOR</div>
      <div class="vuln-desc">View any user's profile</div>
    </a>
    <a href="/change-password" class="vuln-card csrf-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">CSRF</div>
      <div class="vuln-desc">No token on password change</div>
    </a>
    <a href="/debug/session" class="vuln-card info-card">
      <div class="vuln-icon"></div>
      <div class="vuln-name">Info Disclosure</div>
      <div class="vuln-desc">Session data exposed at /debug</div>
    </a>
  </div>
</div>

<div class="section">
  <h2 class="section-title">Latest Posts</h2>
  <% if (posts.length === 0) { %>
    <p class="empty">No posts yet.</p>
  <% } %>
  <% posts.forEach(post => { %>
    <div class="card post-card">
      <div class="post-meta"> <%= post.username %> · <span class="time"><%= post.created_at %></span></div>
      <h3><%= post.title %></h3>
      <p><%= post.content %></p>
    </div>
  <% }) %>
</div>

<div class="section hint-box">
  <h3>Test Credentials</h3>
  <table class="creds-table">
    <tr><th>Username</th><th>Password</th><th>Role</th></tr>
    <tr><td>admin</td><td>admin123</td><td><span class="badge admin">admin</span></td></tr>
    <tr><td>user</td><td>123456</td><td><span class="badge user">user</span></td></tr>
    <tr><td>alice</td><td>alice2024</td><td><span class="badge user">user</span></td></tr>
    <tr><td>bob</td><td>bob2024</td><td><span class="badge user">user</span></td></tr>
  </table>
</div>

<%- include('partials/footer') %>
